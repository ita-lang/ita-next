(* ==========================================================================
   grammar.ebnf — Gramática formal do Itá (ita-next)
   ==========================================================================
   Seção: LEXICAL GRAMMAR (Fase 1). Notação: W3C EBNF (a de XML 1.0 §6,
   https://www.w3.org/TR/xml/#sec-notation) — escolha do ADR-0010 (formato
   formal; geradores Flex/ANTLR proibidos, Princípio 11: zero code generation).

   Convenções W3C EBNF usadas aqui:
     symbol ::= expr        definição
     A B                    sequência
     A | B                  alternativa
     A?                     opcional (0 ou 1)
     A*                     zero ou mais
     A+                     um ou mais
     ( … )                  agrupamento
     "…" ou '…'             terminal literal
     [abc] [a-z]            classe de caracteres / faixa
     [^abc]                 negação de classe
     #xN                    caractere pelo code point hexadecimal
     A - B                  diferença (A que não casa B)
     (* … *)                comentário

   Fonte-da-verdade reconciliada com o `GRAMMAR.md` §1 do `ita/`. Onde este
   arquivo APERTA o `GRAMMAR.md` (frouxo), a divergência está anotada.
   Cada terminal traz, em comentário, o nome da `Tag` emitida
   (ver compiler/lib/frontend/lexer/token.dart).
   ========================================================================== *)


(* ------------------------------------------------------------------------
   1. Identificadores, wildcard e closure-shorthand
   ------------------------------------------------------------------------ *)

(* ASCII-only (D6). `_` SOZINHO é UNDERSCORE; `_` seguido de ao menos um
   ID_CONT (ex.: `_x`, `_1`, `__`) é IDENT — o maximal munch resolve (o mais
   longo vence). Keywords reservadas (§2) NÃO são IDENT: são reconhecidas por
   um mapa após o munch. As contextuais (`from left right all race`) SÃO IDENT. *)
IDENT          ::= [A-Za-z] ID_CONT*
                 | '_' ID_CONT+
ID_CONT        ::= [A-Za-z0-9_]

UNDERSCORE     ::= '_'                      (* Tag: underscore — só quando NÃO seguido de ID_CONT *)

(* O índice tem TETO: 0..255 (`$256`+ → lex-dollar-index-range). A Fase 3
   sintetiza 1 param por índice até o maior `$k` do corpo, logo um índice sem
   teto seria OOM (`{ $3000000 }` → 3M params). 255 = teto clássico de params. *)
CLOSURE_PARAM  ::= '$' [0-9]+               (* Tag: identifier — closure shorthand $0, $1 (§2.1); índice <= 255 *)


(* ------------------------------------------------------------------------
   2. Keywords reservadas (40) — Tag: kw*  (via mapa, após o munch de IDENT)
   ------------------------------------------------------------------------ *)

(* As 36 do GRAMMAR.md §1 + 4 vivas de declaração. NÃO inclui as contextuais
   nem as keywords mortas (`const unsafe effect signal state` — removidas, D1). *)
KEYWORD ::= "pub"  | "fn"    | "async"  | "stream" | "actor"  | "struct"
          | "class"| "enum"  | "trait"  | "impl"   | "extension" | "import"
          | "operator" | "let" | "var"  | "return" | "if"     | "else"
          | "guard"| "while" | "for"    | "await"  | "in"     | "match"
          | "self" | "mut"   | "where"  | "emit"   | "spawn"  | "panic"
          | "break"| "continue" | "true" | "false" | "nil"    | "as"
          | "static" | "init" | "override" | "precedence"


(* ------------------------------------------------------------------------
   3. Literais numéricos — Tag: intLiteral / floatLiteral
   ------------------------------------------------------------------------ *)

(* Separador `_` APERTADO (D4): o padrão ( '_'? DIGIT ) só admite `_` ENTRE
   dígitos — proíbe `_` inicial, final ou duplo. O `GRAMMAR.md` §1 usa
   `[0-9][0-9_]*` (frouxo: casaria `1_`, `1__0`); esta é a reconciliação —
   `1_`, `1__0`, `0xFF_` são `lex-malformed-number`, não tokens. O `literal`
   é computado sobre os dígitos sem `_`. *)
INT            ::= DEC_INT | HEX_INT | BIN_INT
DEC_INT        ::= [0-9]        ( '_'? [0-9] )*
HEX_INT        ::= '0' [xX] [0-9a-fA-F] ( '_'? [0-9a-fA-F] )*
BIN_INT        ::= '0' [bB] [01] ( '_'? [01] )*

(* FLOAT exige `.` seguido de dígito. O expoente só existe NO RAMO COM PONTO
   (D6): `1e10` NÃO é float (→ `1` + `e10`); `1.` NÃO é float (→ `1` + `.`);
   `.5` NÃO é float (→ `.` + `5`). *)
FLOAT          ::= [0-9] ( '_'? [0-9] )* '.' [0-9] ( '_'? [0-9] )* EXPONENT?
EXPONENT       ::= [eE] [+-]? [0-9]+


(* ------------------------------------------------------------------------
   4. Literais de string — Tag: stringLiteral / multilineString
   ------------------------------------------------------------------------ *)

STRING         ::= '"' STRING_ELEM* '"'                 (* Tag: stringLiteral *)
STRING_ELEM    ::= ESCAPE | INTERP | STRING_CHAR
STRING_CHAR    ::= Char - ( '"' | '\' | #xA )           (* qualquer char, menos aspa, barra e newline *)
ESCAPE         ::= '\' ( [nrt0] | '\' | '"' )          (* \n \r \t \0 \\ \" *)

(* R1: `\` seguido de um char FORA desse conjunto (ex.: `\z`) NÃO é texto cru
   tolerado — é o erro `lex-invalid-escape` (não-abortante, span do `\x`). O
   char é mantido no buffer para resync e a tokenização segue. *)

(* Interpolação só em STRING (não em MULTILINE_STRING, D6). O `}` de fecho é
   achado por CONTADOR DE PROFUNDIDADE de `{}` — logo, NÃO é regular (fica
   fora das definições regulares, como o comentário aninhado §6). *)
INTERP         ::= '${' balancedExpr '}'

(* Conteúdo CRU: sem escape, sem interpolação (D6). Fecha no primeiro `"""`. *)
MULTILINE_STRING ::= '"""' ( Char* - ( Char* '"""' Char* ) ) '"""'   (* Tag: multilineString *)


(* ------------------------------------------------------------------------
   5. Operadores e pontuação — maximal munch (o mais longo vence)
   ------------------------------------------------------------------------ *)

(* Ordenados do mais longo para o mais curto NO MESMO PREFIXO (é o que importa
   pro munch): `..=` > `..` ; `<=`/`<<` > `<` ; `>=`/`>>` > `>` ; `?.`/`??` >
   `?` ; `**` > `*`. Comentário = Tag emitida. *)
OPERATOR ::= "..="   (* dotDotEq *)   | ".."  (* dotDot *)
           | "**"    (* starStar *)
           | "+="    (* plusEq *)     | "-="  (* minusEq *)
           | "*="    (* starEq *)     | "/="  (* slashEq *)
           | "->"    (* arrow *)      | "=>"  (* fatArrow *)
           | "=="    (* eqEq *)       | "!="  (* bangEq *)
           | "<="    (* ltEq *)       | ">="  (* gtEq *)
           | "<<"    (* ltLt *)       | ">>"  (* gtGt *)
           | "&&"    (* ampAmp *)     | "||"  (* pipePipe *)
           | "??"    (* questionQuestion *) | "?." (* questionDot *)
           | "|>"    (* pipeGt *)
           | "+"     (* plus *)       | "-"   (* minus *)
           | "*"     (* star *)       | "/"   (* slash *)
           | "%"     (* percent *)    | "!"   (* bang *)
           | "~"     (* tilde *)      | "&"   (* amp *)
           | "|"     (* pipe *)       | "^"   (* caret *)
           | "<"     (* lt *)         | ">"   (* gt *)
           | "="     (* eq *)         | "?"   (* question *)
           | "."     (* dot *)

PUNCT ::= "("  (* lparen *)   | ")"  (* rparen *)
        | "{"  (* lbrace *)   | "}"  (* rbrace *)
        | "["  (* lbracket *) | "]"  (* rbracket *)
        | ","  (* comma *)    | ":"  (* colon *)
        | ";"  (* semicolon *)| "#"  (* hash *)

(* Terminais "mortos" no PARSER, mas TOKENIZADOS pelo léxico (§2.5, D5):
   `#` (hash), `&` (amp), `|` (pipe), `^` (caret), `<<` (ltLt), `~` (tilde). O
   bitwise NÃO tem operador na superfície: é via API `Bits.*` (spec 001 Q2 /
   ADR-0012). O léxico é completo; filtrar é papel de fases posteriores.
   PROIBIDO: `@` → NÃO é terminal; é o erro `lex-annotation-unsupported`
   (Princípio 6, zero annotations, D5). *)


(* ------------------------------------------------------------------------
   6. Ignorados entre tokens (não viram Token; comentários vão p/ `comments`)
   ------------------------------------------------------------------------ *)

WHITESPACE     ::= ( #x20 | #x9 | #xD | #xA )+           (* espaço, tab, CR, LF *)
LINE_COMMENT   ::= '//' ( Char - #xA )*

(* Comentário de bloco ANINHÁVEL. O aninhamento é resolvido por CONTADOR DE
   PROFUNDIDADE — logo NÃO é linguagem regular (fica fora das definições
   regulares; nota normativa §2.4 da spec). A produção abaixo é ilustrativa. *)
BLOCK_COMMENT  ::= '/*' ( BLOCK_COMMENT | ( Char - ( '/*' | '*/' ) ) )* '*/'


(* ------------------------------------------------------------------------
   7. Fluxo de tokens e erros
   ------------------------------------------------------------------------ *)

(* O léxico produz a sequência de tokens terminada por `eof` (Tag: eof).
   Erros léxicos são NÃO-ABORTANTES (D3): o lexer emite `invalid` (Tag:
   invalid) para resync e coleta o erro. Taxonomia (EN kebab-case):
     lex-unexpected-char, lex-unterminated-string,
     lex-unterminated-multiline-string, lex-unterminated-block-comment,
     lex-annotation-unsupported, lex-malformed-number,
     lex-integer-overflow, lex-invalid-escape, lex-dollar-index-range.
   (lex-integer-overflow: INT bem-formado > Int64 — inclui hex/bin de 64+ bits,
    ex. 0xFFFFFFFFFFFFFFFF; lex-invalid-escape: `\` + char fora do ESCAPE §4;
    lex-dollar-index-range: CLOSURE_PARAM com índice > 255, ex. $3000000.)  *)
tokens         ::= ( TOKEN )* eof
TOKEN          ::= IDENT | CLOSURE_PARAM | UNDERSCORE | KEYWORD
                 | INT | FLOAT | STRING | MULTILINE_STRING
                 | OPERATOR | PUNCT


(* ==========================================================================
   SYNTACTIC GRAMMAR (Fase 2 — spec 004). Reconciliada com o `GRAMMAR.md`
   §2–§6 do `ita/`. Terminais em MAIÚSCULAS são os da seção léxica; keywords
   e sinais vão entre aspas. A precedência de expressão NÃO mora aqui (seria
   "torre ilegível") — é a escada §10 (uma produção por nível). Divergências
   deliberadas vs o parser do `ita/` marcadas com (Δ); deferrals com (DEFER).
   O parser vence: se este arquivo e o parser divergirem, este é o bug.
   ========================================================================== *)


(* ------------------------------------------------------------------------
   8. Programa e declarações (§2 GRAMMAR.md)
   ------------------------------------------------------------------------ *)

program        ::= item* eof
item           ::= declaration | statement          (* statements no escopo de módulo *)

declaration    ::= "pub"? typeDecl
                 | implDecl | extensionDecl | importDecl | operatorDecl   (* "pub" aqui = erro *)

(* (Δ D3) `pub` diante de impl/extension/import/operator é `meaningless-pub`
   (error production, DB 4.1.4) — o oracle consumia mudo. *)
typeDecl       ::= fnDecl | "async" fnDecl | "stream" fnDecl
                 | structDecl | classDecl | enumDecl | traitDecl | actorDecl

fnDecl         ::= ("static" | "override")* "fn" IDENT genericParams?
                   "(" paramList ")" ( "->" type )? fnBody?
fnBody         ::= "=>" ( block | expression ) | block
genericParams  ::= "<" genericParam ( "," genericParam )* ">"     (* fecha com token-split de ">>" *)
genericParam   ::= IDENT ( ":" type ( "+" type )* )?
paramList      ::= ( param ( "," param )* ","? )?                 (* (DEFER) grupo nomeado ";" *)
param          ::= IDENT IDENT? ( ":" type )? ( "=" expression )?  (* 2 IDENTs = label + nome *)

(* Conformances inline (spec 005 §3.1c): struct/extension → todos os `type` após
   `:` são traits; class → 1º type = superclasse, demais = traits (GRAMMAR.md §2). *)
structDecl     ::= "struct" IDENT genericParams? ( ":" type ( "," type )* )? typeBody
classDecl      ::= "class" IDENT genericParams? ( ":" type ( "," type )* )? typeBody
enumDecl       ::= "enum" IDENT genericParams? "{" enumMember* "}"
traitDecl      ::= "trait" IDENT genericParams? typeBody
actorDecl      ::= "actor" IDENT typeBody
implDecl       ::= "impl" type ( "for" type )? typeBody
extensionDecl  ::= "extension" type ( ":" type ( "," type )* )? typeBody
operatorDecl   ::= "operator" OPSYM "(" paramList ")" "->" type
                   ( "precedence" INT ("left"|"right")? )? block    (* assoc preservada no modelo (D3) *)

typeBody       ::= "{" ( member ( "," | ";" )? )* "}"
member         ::= "pub"? ( ("async"|"stream")? fnDecl | initDecl | field )
initDecl       ::= "init" "(" paramList ")" block                  (* construtor (spec 005 §3.1a) *)
field          ::= ( "var" | "let" )? IDENT ":" type ( "=" expression )?
enumMember     ::= "pub"? ("async"|"stream")? fnDecl | enumCase ( "," | ";" )?
enumCase       ::= IDENT ( "(" ( param ( "," param )* )? ")" )?

importDecl     ::= "import" "{" importMember ( "," importMember )* ","? "}" "from" STRING
                 | "import" "*" "as" IDENT "from" STRING
                 | "import" STRING
importMember   ::= IDENT ( "as" IDENT )?           (* "from" é IDENT contextual, não keyword *)


(* ------------------------------------------------------------------------
   9. Statements (§3 GRAMMAR.md)
   ------------------------------------------------------------------------ *)

statement      ::= letStmt | varStmt | returnStmt | ifStmt | guardStmt
                 | whileStmt | forStmt | "break" | "continue"
                 | emitStmt | block | exprStmt
(* `let` LIGA um valor ⟹ exige `= e` (`let-requires-value`); `var` é SLOT mutável
   ⟹ init opcional na forma bind (definite-assignment é F6). A assimetria é P1
   virando FORMA. Destructure (`[…]`/`{…}`) exige `= e` nos dois — não há o que
   ligar sem valor. Ruling do dono 2026-07-15 (spec 009 §12-7); fecha o §Aberto
   do nullity-invariant.md. NÃO custa imutabilidade: `if`/`match`-expr (P3),
   `where {…}` (ADR-0012 A4) e `f()?`/`guard let` (P7) cobrem os três casos. *)
letStmt        ::= "let" pattern ( ":" type )? "=" expression
varStmt        ::= "var" ( bindPattern ( ":" type )? ( "=" expression )?
                         | pattern ( ":" type )? "=" expression )
returnStmt     ::= "return" expression?
ifStmt         ::= "if" expression block ( "else" ( ifStmt | block ) )?   (* dangling-else → if interno *)
guardStmt      ::= "guard" ( "let" pattern "=" pipeNoAnd ( "&&" expression )?
                           | expression ) "else" block   (* (Δ spec 005 §3.1b) `&&`-refino, split no 1º `&&`: value = `pipeNoAnd`, condition = o resto *)
(* `pipeNoAnd` = a produção `pipe` (nível 2) com o `&&` de NÍVEL-TOPO reservado
   ao refino — parse contextual, não um nível novo na cascata. Cobre `??`/`||`/
   `|>`/`>>` no valor; dentro de qualquer delimitador (`(…)`, args, `[…]`, corpo
   de closure) o `&&` volta a ser o operador normal:
     guard let v = a ?? b && c   → value = (a ?? b),  condition = c
     guard let v = a && b && c   → value = a,         condition = (b && c)
     guard let v = (a && b)      → value = (a && b),  condition = ausente
   (Antes: `equality` (nível 6). Parava no `&&`, mas ficava ABAIXO de
   `??`/`||`/`|>`/`>>` — os quatro não parseavam no valor.) *)
pipeNoAnd      ::= pipe
whileStmt      ::= "while" expression block
forStmt        ::= "for" "await"? pattern "in" expression block
emitStmt       ::= "emit" expression
block          ::= "{" ( statement ";"? )* "}"
exprStmt       ::= expression

(* (Δ canto 7) A condição de if/while/for/match SUPRIME a trailing-closure
   (o `{` ali é bloco/arms); `guard` NÃO suprime (o `{}` da condição é closure).
   (Δ canto 3) Em posição de statement `{` é bloco; em expressão, é map. *)


(* ------------------------------------------------------------------------
   10. Expressões — escada de precedência (§4.2). Do mais FROUXO ao mais FORTE.
   ------------------------------------------------------------------------ *)

expression     ::= whereExpr
whereExpr      ::= assignment ( "where" "{" ( whereBinding ";"? )+ "}" )?   (* (Δ spec 006) nível 0, o mais frouxo; só "let"/"var" no bloco; UM "where" por expr (não-assoc) *)
(* Δ vs `varStmt`: o init é OBRIGATÓRIO aqui, para os DOIS. `var y` sem valor é
   legal num bloco (é slot — enche depois), mas `where` é EXPRESSÃO e não há
   "depois". Sem `=`: where-binding-needs-value. (Senão a Fase 3 fabricaria
   `match nil`, injetando nil sob tipo não-opcional — ver nullity-invariant.md.)
   Δ 2026-07-15: `let` sem init já morre antes, em `let-requires-value` (§letStmt)
   — o `let` exige valor em qualquer lugar, então esta regra só pega o `var`. *)
   Os nomes ligados pelos bindings de um mesmo `where` são DISTINTOS entre si:
   repetir é where-duplicate-binding, não shadowing (a Fase 3 aninha em matches,
   onde a Fase 4 leria os escopos como shadowing legítimo e nunca acusaria). *)
whereBinding   ::= ( "let" | "var" ) pattern ( ":" type )? "=" expression
assignment     ::= pipe ( ( "=" | "+=" | "-=" | "*=" | "/=" ) assignment )?   (* direita *)
pipe           ::= nilCoalesce ( ( "|>" | ">>" ) nilCoalesce )*
nilCoalesce    ::= or ( "??" or )*                  (* (Δ CA9) "||" liga mais forte que "??" *)
or             ::= and ( "||" and )*
and            ::= equality ( "&&" equality )*
equality       ::= comparison ( ( "==" | "!=" ) comparison )*
comparison     ::= range ( ( "<" | ">" | "<=" | ">=" ) range )*   (* (Δ D2) "<" é sempre comparação *)
range          ::= addition ( ( ".." | "..=" ) addition )?        (* (Δ CA10) não-associativo *)
addition       ::= multiplication ( ( "+" | "-" ) multiplication )*
multiplication ::= power ( ( "*" | "/" | "%" ) power )*
power          ::= unary ( "**" power )?            (* direita *)
unary          ::= ( "!" | "-" ) unary                (* `~` é morto-no-parser: bitwise via API Bits.* (spec 001 Q2 / ADR-0012) *)
                 | ( "await" | "spawn" | "panic" ) unary          (* (Δ D4) prefixos ligam no unário *)
                 | postfix
postfix        ::= primary postfixOp*
postfixOp      ::= "(" argList ")" trailingClosure?  (* call — "(" só na MESMA linha *)
                 | "." "{" fieldInit ( "," fieldInit )* "}"       (* copy-with *)
                 | "." INT                                        (* tuple-index *)
                 | "." IDENT trailingClosure?                     (* member — "." só na MESMA linha *)
                 | "?." IDENT | "[" expression "]" | "!" | "?"
argList        ::= ( arg ( "," arg )* ","? )?
arg            ::= ( IDENT ":" )? expression
fieldInit      ::= IDENT ":" expression
trailingClosure ::= block                            (* (Δ CA13) só na MESMA linha do ")"/member *)

primary        ::= INT | FLOAT | STRING | MULTILINE_STRING
                 | "true" | "false" | "nil" | "self" | IDENT
                 | matchExpr | ifExpr | parenOrClosure | listLiteral | mapLiteral
                 | "async" closure                                (* async closure: só em "async (" *)
                 | "." IDENT                                      (* enum shorthand *)

(* if-EXPRESSÃO (ruling RD-1, opção A): ramos = EXPRESSÃO via "=>", `else`
   OBRIGATÓRIO. `=>` é o único token "rende valor" no Itá. A forma if-let
   (`if let PAT = e => …`) desembrulha. Distinto do if-STATEMENT (§9, blocos)
   por posição — só se chega em posição de expressão. *)
ifExpr         ::= "if" ( "let" pattern "=" )? expression "=>" expression
                   "else" ( ifExpr | expression )

parenOrClosure ::= closure | "(" expression ( "," expression )* ","? ")"
                   (* 1 elem = grupo; >=2 = tupla; "(a,)" = single-element-tuple (M7, Δ) *)
closure        ::= "(" paramList ")" ( "->" type )? ( "=>" ( block | expression ) | block )
listLiteral    ::= "[" ( expression ( "," expression )* ","? )? "]"
mapLiteral     ::= "{" ( expression ":" expression ( "," … )* ","? )? "}"   (* {…} em EXPR = map (D1) *)
matchExpr      ::= "match" expression "{" matchArm* "}"
matchArm       ::= pattern ( "if" expression )? "=>" expression ","?

(* interpolação `${…}` é REPARSEADA como `expression` em parse-time (Δ M3);
   o nó Str guarda partes ordenadas literal|expr. *)


(* ------------------------------------------------------------------------
   11. Tipos (§5 GRAMMAR.md)
   ------------------------------------------------------------------------ *)

type           ::= "mut" type
                 | "async" type                                   (* inner deve ser tipo-função *)
                 | "(" ( type ( "," type )* ","? )? ")" ( "->" type )? "?"?   (* grupo/tupla/função *)
                 | IDENT ( "<" type ( "," type )* ">" )? "?"?      (* nomeado + generics + optional *)


(* ------------------------------------------------------------------------
   12. Patterns (§6 GRAMMAR.md)
   ------------------------------------------------------------------------ *)

pattern        ::= "_"
                 | "." IDENT ( "(" ( pattern ( "," pattern )* )? ")" )?   (* enum variant *)
                 | "[" ( patElem ( "," patElem )* )? "]"                  (* list *)
                 | "{" ( fieldPat ( "," fieldPat )* )? "}"                (* record destructure *)
                 | IDENT "{" ( fieldPat ( "," fieldPat )* )? ".."? "}"    (* struct (lookahead IDENT "{") *)
                 | INT ( ( ".." | "..=" ) INT )?                          (* range OU literal *)
                 | FLOAT | STRING | "true" | "false" | "nil"
                 | IDENT                                                  (* binding *)
patElem        ::= ".." IDENT? | pattern
fieldPat       ::= IDENT ( ":" pattern )?
