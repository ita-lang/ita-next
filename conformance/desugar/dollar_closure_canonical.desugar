(let (bind "a") (call (member (id xs) "map") (closure (params (param "$0") (param "$1")) (* (id $1) (int 2)))))
(let (bind "b") (call (member (id xs) "map") (closure (params (param "$0") (param "$1")) (+ (id $1) (id $1)))))
(let (bind "c") (call (member (id xs) "map") (closure (params (param "$0") (param "$1") (param "$2") (param "$3") (param "$4") (param "$5") (param "$6") (param "$7")) (id $7))))
